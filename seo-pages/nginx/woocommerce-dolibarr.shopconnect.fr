server {
    listen 80;
    listen [::]:80;
    server_name woocommerce-dolibarr.shopconnect.fr;
    root /var/www/connecteurs/woocommerce-dolibarr.shopconnect.fr;
    index index.html;
    charset utf-8;
    location / {
        try_files $uri /index.html =404;
    }
    location ~* \.(html|css|js|ico|png|jpg|svg)$ {
        expires 1d;
        add_header Cache-Control "public";
    }
}
