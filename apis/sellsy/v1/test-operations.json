      "request": { "method": "Document.getList", "params": { "doctype": "proforma", "pagination": { "pagenum": 1, "nbperpage": 10 } } }
    },
    {
      "id": "document_getList_model",
      "label": "Document — Liste des modèles",
      "request": { "method": "Document.getList", "params": { "doctype": "model", "pagination": { "pagenum": 1, "nbperpage": 10 } } }
