{
  "description": "Opérations RPC à exécuter pour tester Catalogue, Documents (chaque type), Clients",
  "baseUrl": "https://api.sellsy.com",
  "method": "POST",
  "contentType": "application/json",
  "operations": [
    {
      "id": "catalogue_getList_item",
      "label": "Catalogue — Liste des produits (items)",
      "request": { "method": "Catalogue.getList", "params": { "type": "item", "pagination": { "pagenum": 1, "nbperpage": 10 } } }
    },
    {
      "id": "catalogue_getList_service",
      "label": "Catalogue — Liste des services",
      "request": { "method": "Catalogue.getList", "params": { "type": "service", "pagination": { "pagenum": 1, "nbperpage": 10 } } }
    },
    {
      "id": "catalogue_getCategories",
      "label": "Catalogue — Catégories",
      "request": { "method": "Catalogue.getCategories", "params": {} }
    },
    {
      "id": "document_getList_invoice",
      "label": "Document — Liste des factures",
