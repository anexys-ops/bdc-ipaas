{
  "connector_meta": {
    "id": "dolibarr",
    "name": "Dolibarr",
    "version": "1.0",
    "icon": "https://logo.clearbit.com/dolibarr.org",
    "category": "ERP / CRM",
    "auth_type": "api_key",
    "docs_url": "https://wiki.dolibarr.org/index.php/API",
    "config_instructions": "1) Activer l'API : Accueil → Configuration → Modules/Applications → activer « Web services REST API ». 2) Créer une clé API : menu utilisateur (en haut à droite) → onglet « Clé API » → Générer ou régénérer. Copier la clé (DOLAPIKEY) et la conserver en lieu sûr. 3) URL de base : saisir l'URL complète (ex: https://votre-instance.fr/api/index.php) ou le domaine (ex: https://votre-instance.fr) — /api/index.php est ajouté si absent. En-tête : DOLAPIKEY. Doc : https://wiki.dolibarr.org/index.php/Module_Web_Services_API_REST_(developer)"
  },
  "auth_config": {
    "api_key_header": "DOLAPIKEY",
    "base_url_param": "base_url"
  },
  "config_fields": [
    {
      "key": "base_url",
      "label": "URL de base",
      "type": "text",
      "required": true,
      "placeholder": "https://luxgreen.fr ou https://votre-instance.fr/api/index.php",
      "description": "Domaine seul (ex: https://luxgreen.fr) ou URL complète avec /api/index.php. Le chemin /api/index.php est ajouté automatiquement si absent."
    },
    {
      "key": "api_key",
      "label": "Clé API (DOLAPIKEY)",
      "type": "password",
      "required": true,
      "placeholder": "Votre clé générée dans Dolibarr",
      "description": "Clé API générée dans le profil utilisateur (onglet Clé API). Envoyée dans l'en-tête DOLAPIKEY."
    }
  ],
