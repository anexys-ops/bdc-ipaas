{
  "connector_meta": {
    "id": "woocommerce",
    "name": "WooCommerce",
    "version": "3.0",
    "icon": "https://logo.clearbit.com/woocommerce.com",
    "category": "E-commerce",
    "auth_type": "oauth1",
    "docs_url": "https://woocommerce.github.io/woocommerce-rest-api-docs/",
    "config_instructions": "WooCommerce REST API (OAuth 1.0a) : 1) Dans WordPress : Réglages → Avancé → REST API. 2) Ajouter une clé : Description (ex: ANEXYS iPaaS), utilisateur, permissions (Lecture/Écriture). Générer la clé. 3) Conserver la Consumer key (ck_...) et la Consumer secret (cs_...) en lieu sûr (le secret ne s'affiche qu'une fois). 4) URL du site = URL de la boutique (ex: https://votre-boutique.com). Les requêtes iront sur /wp-json/wc/v3/. Doc : https://woocommerce.github.io/woocommerce-rest-api-docs/"
  },
  "auth_config": {
    "consumer_key_param": "consumer_key",
    "consumer_secret_param": "consumer_secret",
    "base_url_param": "shop_url"
  },
  "config_fields": [
    {
      "key": "shop_url",
      "label": "URL du site / boutique",
      "type": "text",
      "required": true,
      "placeholder": "https://votre-boutique.com",
      "description": "URL de la boutique WordPress/WooCommerce (sans slash final). Ex: https://monshop.com"
    },
    {
      "key": "consumer_key",
      "label": "Consumer Key (ck_...)",
      "type": "text",
      "required": true,
      "placeholder": "ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "description": "Clé consommateur affichée lors de la création de la clé API (Réglages → Avancé → REST API)."
    },
    {
      "key": "consumer_secret",
      "label": "Consumer Secret (cs_...)",
      "type": "password",
      "required": true,
      "placeholder": "cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "description": "Secret consommateur. Affiché une seule fois à la création de la clé ; à conserver en lieu sûr."
    }
  ],
  "operations": [
