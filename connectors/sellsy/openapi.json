{
  "connector_meta": {
    "id": "sellsy",
    "name": "Sellsy",
    "version": "2.0",
    "icon": "https://logo.clearbit.com/sellsy.com",
    "category": "CRM / Facturation",
    "auth_type": "oauth2",
    "docs_url": "https://api.sellsy.com/doc/v2/",
    "config_instructions": "1) Rendez-vous sur https://www.sellsy.com/developer/api-v2 (ou Sellsy → Paramètres → Intégrations → API). 2) Créez une application pour obtenir le Client ID et le Client Secret. 3) Le token d’accès est obtenu automatiquement (flux Client Credentials) à partir de ces identifiants ; inutile de saisir un token manuellement. 4) URL de base par défaut : https://api.sellsy.com/v2 (optionnel). Doc : https://api.sellsy.com/doc/v2/"
  },
  "auth_config": {
    "token_url": "https://login.sellsy.com/oauth2/access-tokens",
    "authorization_url": "https://login.sellsy.com/oauth2/authorization",
    "scopes": ["invoices.read", "invoices.write", "contacts.read", "contacts.write", "opportunities.read"]
  },
  "config_fields": [
    {
      "key": "client_id",
      "label": "Client ID",
      "type": "text",
      "required": true,
      "placeholder": "Ex: e3bccf5e-40a9-4109-8e05-160fd93cf47e",
      "description": "Identifiant de l'application (Sellsy Developer). Le token est récupéré automatiquement avec le Client Secret."
    },
    {
      "key": "client_secret",
      "label": "Client Secret",
      "type": "password",
      "required": true,
      "placeholder": "Secret de l'application Sellsy",
      "description": "Secret de l'application. Avec le Client ID, permet d'obtenir automatiquement le token d'accès."
    },
    {
      "key": "base_url",
      "label": "URL de base API",
      "type": "text",
      "required": false,
      "placeholder": "https://api.sellsy.com/v2",
      "description": "Optionnel. Par défaut : https://api.sellsy.com/v2. Ne pas utiliser login.sellsy.com (réservé à l'OAuth)."
    }
  ],
