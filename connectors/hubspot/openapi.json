{
  "connector_meta": {
    "id": "hubspot",
    "name": "HubSpot",
    "version": "1.0",
    "icon": "https://logo.clearbit.com/hubspot.com",
    "category": "CRM / Marketing",
    "auth_type": "oauth2",
    "docs_url": "https://developers.hubspot.com/docs/api/overview",
    "config_instructions": "1) HubSpot : Paramètres (Settings) → Intégrations → Private Apps (ou OAuth). 2) Private App : créez une app, définissez les scopes (crm.objects.contacts.read/write, crm.objects.companies.read/write, etc.), récupérez le token. 3) OAuth : créez une app sur https://developers.hubspot.com, configurez redirect_uri et scopes, récupérez Client ID et Secret ; après autorisation utilisez l’access_token. URL de base : https://api.hubapi.com. Doc : https://developers.hubspot.com/docs/api/overview"
  },
  "auth_config": {
    "token_url": "https://api.hubapi.com/oauth/v1/token",
