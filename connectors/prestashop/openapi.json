{
  "connector_meta": {
    "id": "prestashop",
    "name": "PrestaShop",
    "version": "1.7",
    "icon": "https://logo.clearbit.com/prestashop.com",
    "category": "E-commerce",
    "auth_type": "basic",
    "docs_url": "https://devdocs.prestashop-project.org/8/webservice/",
    "config_instructions": "PrestaShop : 1) Activer le Web Service : Paramètres avancés → Web Service → activer et cocher « Activer le webservice ». 2) Créer une clé API : Ajouter une clé, définir les permissions (lecture/écriture selon besoin). Copier la clé (ex: UCCLLQ9N2ARSHWCXLT74KUKSSK34BFKX). 3) Authentification : PrestaShop utilise HTTP Basic ; l'identifiant = la clé API, le mot de passe = vide. 4) URL de base = URL de la boutique (ex: https://votre-boutique.com). L'API est sous /api/. Doc : https://devdocs.prestashop-project.org/8/webservice/tutorials/testing-access/"
  },
  "auth_config": {
    "auth_method": "basic",
    "username_param": "username",
    "password_param": "password",
    "base_url_param": "shop_url"
  },
  "config_fields": [
    {
      "key": "shop_url",
      "label": "URL de la boutique",
      "type": "text",
      "required": true,
      "placeholder": "https://votre-boutique.com",
      "description": "URL racine de la boutique PrestaShop (sans slash final). L'API sera appelée sur /api/."
    },
    {
      "key": "username",
      "label": "Clé API (identifiant Web Service)",
      "type": "password",
      "required": true,
      "placeholder": "Votre clé API PrestaShop",
      "description": "Clé générée dans Paramètres avancés → Web Service. Utilisée comme identifiant en Basic Auth."
    },
    {
      "key": "password",
      "label": "Mot de passe (laisser vide)",
      "type": "password",
      "required": false,
      "placeholder": "(vide)",
      "description": "PrestaShop n'utilise pas de mot de passe : laisser vide."
    }
  ],
  "operations": [
    {
      "id": "list_customers",
