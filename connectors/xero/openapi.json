      "label": "Récupérer les contacts",
      "type": "source",
      "method": "GET",
      "path": "/Contacts",
      "output_schema": {
        "type": "object",
        "properties": {
          "Contacts": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ContactID": { "type": "string" },
                "Name": { "type": "string" },
                "EmailAddress": { "type": "string" },
                "Phones": { "type": "array" },
                "IsCustomer": { "type": "boolean" },
                "IsSupplier": { "type": "boolean" }
              }
            }
          }
        }
      }
    },
