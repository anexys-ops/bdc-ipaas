{
  "connector_meta": {
    "id": "xero",
    "name": "Xero",
    "version": "1.0",
    "icon": "https://logo.clearbit.com/xero.com",
    "category": "Comptabilité",
    "auth_type": "oauth2",
    "docs_url": "https://developer.xero.com/documentation/api/overview",
    "config_instructions": "Xero : Developer Portal → My Apps → New app. OAuth 2.0 avec scopes openid profile email accounting.contacts accounting.transactions. URL de base : https://api.xero.com/api.xro/2.0. Collez l'access_token après connexion OAuth2."
  },
  "auth_config": {
    "token_url": "https://identity.xero.com/connect/token",
    "scopes": ["openid", "profile", "email", "accounting.contacts", "accounting.transactions"]
