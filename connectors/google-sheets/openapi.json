{
  "connector_meta": {
    "id": "google-sheets",
    "name": "Google Sheets",
    "version": "1.0",
    "icon": "https://logo.clearbit.com/google.com",
    "category": "Tableurs",
    "auth_type": "oauth2",
    "docs_url": "https://developers.google.com/sheets/api/reference/rest",
    "config_instructions": "1) Google Cloud Console : https://console.cloud.google.com → APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID. 2) Type : Application Web. Définissez l’URI de redirection autorisée. 3) Activez l’API Google Sheets (APIs & Services → Library → Google Sheets API). 4) Scopes : https://www.googleapis.com/auth/spreadsheets, https://www.googleapis.com/auth/drive. 5) Après autorisation, utilisez l’access_token. URL de base : https://sheets.googleapis.com/v4. Doc : https://developers.google.com/sheets/api/guides/authorizing"
  },
  "auth_config": {
    "token_url": "https://oauth2.googleapis.com/token",
    "scopes": ["https://www.googleapis.com/auth/spreadsheets", "https://www.googleapis.com/auth/drive.readonly"]
  },
  "operations": [
    {
      "id": "get_spreadsheet",
      "label": "Récupérer une feuille (métadonnées)",
      "type": "source",
      "method": "GET",
      "path": "/spreadsheets/{spreadsheetId}",
      "output_schema": {
        "type": "object",
        "properties": {
          "spreadsheetId": { "type": "string" },
          "properties": {
            "type": "object",
            "properties": {
              "title": { "type": "string" }
            }
          },
          "sheets": { "type": "array" }
        }
      }
    },
    {
      "id": "get_values",
      "label": "Récupérer les valeurs d’une plage",
      "type": "source",
      "method": "GET",
      "path": "/spreadsheets/{spreadsheetId}/values/{range}",
      "output_schema": {
        "type": "object",
        "properties": {
          "range": { "type": "string" },
          "values": { "type": "array", "items": { "type": "array" } }
        }
      }
    },
    {
      "id": "update_values",
      "label": "Mettre à jour des cellules",
      "type": "destination",
      "method": "PUT",
      "path": "/spreadsheets/{spreadsheetId}/values/{range}",
      "input_schema": {
        "type": "object",
        "required": ["values"],
        "properties": {
          "values": {
            "type": "array",
            "items": { "type": "array" }
          },
          "valueInputOption": { "type": "string", "enum": ["RAW", "USER_ENTERED"] }
        }
      }
    }
  ]
}
