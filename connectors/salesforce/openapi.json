{
  "connector_meta": {
    "id": "salesforce",
    "name": "Salesforce",
    "version": "1.0",
    "icon": "https://logo.clearbit.com/salesforce.com",
    "category": "CRM / Ventes",
    "auth_type": "oauth2",
    "docs_url": "https://developer.salesforce.com/docs/apis",
    "config_instructions": "1) Salesforce : Setup (Paramètres) → Apps → App Manager → New Connected App. 2) Cochez « Enable OAuth Settings », définissez la Callback URL et les scopes (api, refresh_token). 3) Récupérez Consumer Key (Client ID) et Consumer Secret. 4) Après autorisation, utilisez access_token et refresh_token. URL de base : https://votre-instance.salesforce.com/services/data/v59.0. Doc : https://developer.salesforce.com/docs/atlas.en-us.api_rest.meta/api_rest/"
  },
  "auth_config": {
    "token_url": "https://login.salesforce.com/services/oauth2/token",
    "scopes": ["api", "refresh_token"]
  },
