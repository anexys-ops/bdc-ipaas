{
  "connector_meta": {
    "id": "notion",
    "name": "Notion",
    "version": "1.0",
    "icon": "https://logo.clearbit.com/notion.so",
    "category": "Productivité / Docs",
    "auth_type": "oauth2",
    "docs_url": "https://developers.notion.com/reference",
    "config_instructions": "Notion : developers.notion.com → New integration. OAuth (ou Internal Integration pour token interne). Scopes : lecture/écriture des pages et bases. URL de base : https://api.notion.com/v1. En-tête : Authorization: Bearer <token>, Notion-Version: 2022-06-28"
  },
  "auth_config": {
    "token_url": "https://api.notion.com/v1/oauth/token",
    "scopes": []
  },
  "operations": [
    {
      "id": "list_databases",
      "label": "Récupérer les bases",
      "type": "source",
      "method": "GET",
      "path": "/search",
      "output_schema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "array" },
          "url": { "type": "string" },
          "object": { "type": "string" }
        }
      }
    },
    {
      "id": "query_database",
      "label": "Interroger une base (enregistrements)",
      "type": "source",
      "method": "POST",
      "path": "/databases/{database_id}/query",
      "input_schema": {
        "type": "object",
        "properties": {
          "page_size": { "type": "number" },
          "sorts": { "type": "array" }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "results": { "type": "array" },
          "next_cursor": { "type": "string" }
        }
      }
    },
    {
      "id": "create_page",
      "label": "Créer une page",
      "type": "destination",
      "method": "POST",
      "path": "/pages",
      "input_schema": {
        "type": "object",
        "required": ["parent"],
        "properties": {
          "parent": { "type": "object" },
          "properties": { "type": "object" },
          "children": { "type": "array" }
        }
      }
    }
  ]
}
