{
  "connector_meta": {
    "id": "shopify",
    "name": "Shopify",
    "version": "2.0",
    "icon": "https://logo.clearbit.com/shopify.com",
    "category": "E-commerce",
    "auth_type": "oauth2",
    "docs_url": "https://shopify.dev/docs/api/admin-rest",
    "config_instructions": "1) Shopify Admin : Paramètres → Applications et canaux de vente → Développer des applications → Créer une application. 2) Configuration → URL de redirection OAuth et scopes (read_customers, write_customers, read_orders, write_orders, read_products, write_products, read_inventory, write_inventory). 3) Récupérez Client ID et Client Secret. Après autorisation du marchand, utilisez l’access_token. 4) URL de base : https://votre-boutique.myshopify.com/admin/api/2024-01. Doc : https://shopify.dev/docs/api/admin-rest"
  },
  "auth_config": {
    "token_url": "https://votre-boutique.myshopify.com/admin/oauth/access_token",
    "scopes": ["read_customers", "write_customers", "read_orders", "write_orders", "read_products", "write_products", "read_inventory", "write_inventory"]
  },
  "operations": [
    {
      "id": "list_customers",
      "label": "Récupérer les clients",
      "type": "source",
      "method": "GET",
      "path": "/customers.json",
      "pagination": "cursor",
      "output_schema": {
        "type": "object",
        "properties": {
          "id": { "type": "number", "description": "ID Shopify du client" },
          "email": { "type": "string", "format": "email" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "phone": { "type": "string" },
          "verified_email": { "type": "boolean" },
          "tax_exempt": { "type": "boolean" },
          "tags": { "type": "string" },
          "orders_count": { "type": "number" },
          "total_spent": { "type": "string" },
          "state": { "type": "string", "enum": ["disabled", "invited", "declined", "enabled"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "default_address": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "address1": { "type": "string" },
              "address2": { "type": "string" },
              "city": { "type": "string" },
              "province": { "type": "string" },
              "country": { "type": "string" },
              "zip": { "type": "string" },
              "phone": { "type": "string" },
              "company": { "type": "string" }
            }
          }
        }
      }
    },
