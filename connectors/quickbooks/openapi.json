          "DisplayName": { "type": "string" },
          "PrimaryEmailAddr": { "type": "object", "properties": { "Address": { "type": "string" } } },
          "PrimaryPhone": { "type": "object", "properties": { "FreeFormNumber": { "type": "string" } } },
