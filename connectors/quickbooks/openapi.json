{
  "connector_meta": {
    "id": "quickbooks",
    "name": "QuickBooks Online",
    "version": "1.0",
    "icon": "https://logo.clearbit.com/intuit.com",
    "category": "Comptabilité",
    "auth_type": "oauth2",
    "docs_url": "https://developer.intuit.com/app/developer/qbo/docs/api/accounting/all-entities/account",
    "config_instructions": "QuickBooks : Intuit Developer Portal → Create app → OAuth 2.0. Scopes : com.intuit.quickbooks.accounting. URL de base : https://quickbooks.api.intuit.com/v3/company/{realmId}. Utilisez access_token (et refresh_token pour renouveler). realmId = ID du cabinet QuickBooks."
  },
  "auth_config": {
    "token_url": "https://oauth.platform.intuit.com/oauth2/v1/tokens/bearer",
    "scopes": ["com.intuit.quickbooks.accounting"]
  },
  "operations": [
    {
      "id": "list_customers",
      "label": "Récupérer les clients",
      "type": "source",
      "method": "GET",
      "path": "/company/{realmId}/query?query=select * from Customer",
      "output_schema": {
        "type": "object",
        "properties": {
          "QueryResponse": {
            "type": "object",
            "properties": {
              "Customer": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "Id": { "type": "string" },
                    "DisplayName": { "type": "string" },
                    "PrimaryEmailAddr": { "type": "object", "properties": { "Address": { "type": "string" } } },
                    "PrimaryPhone": { "type": "object", "properties": { "FreeFormNumber": { "type": "string" } } },
                    "Balance": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "id": "get_customer",
      "label": "Obtenir un client",
      "type": "source",
      "method": "GET",
      "path": "/company/{realmId}/customer/{customerId}",
      "input_schema": {
        "type": "object",
        "required": ["realmId", "customerId"],
        "properties": {
          "realmId": { "type": "string" },
          "customerId": { "type": "string" }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "Customer": {
            "type": "object",
            "properties": {
              "Id": { "type": "string" },
              "DisplayName": { "type": "string" },
              "PrimaryEmailAddr": { "type": "object", "properties": { "Address": { "type": "string" } } },
              "PrimaryPhone": { "type": "object", "properties": { "FreeFormNumber": { "type": "string" } } },
              "Balance": { "type": "number" },
              "BillAddr": { "type": "object" },
              "SyncToken": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "id": "create_customer",
      "label": "Créer un client",
      "type": "destination",
      "method": "POST",
      "path": "/company/{realmId}/customer",
      "input_schema": {
        "type": "object",
