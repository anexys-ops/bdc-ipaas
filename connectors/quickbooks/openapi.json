    {
      "id": "query_customers",
      "label": "Requête clients (SQL-like)",
      "type": "source",
      "method": "GET",
      "path": "/company/{realmId}/query",
      "input_schema": {
        "type": "object",
        "required": ["realmId", "query"],
        "properties": {
          "realmId": { "type": "string" },
          "query": { "type": "string", "description": "Requête SQL-like (ex: select * from Customer where DisplayName like '%Acme%')" }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "QueryResponse": {
            "type": "object",
            "properties": {
              "Customer": {
                "type": "array",
                "items": { "type": "object" }
              },
              "startPosition": { "type": "integer" },
              "maxResults": { "type": "integer" }
            }
          }
        }
      }
    },
