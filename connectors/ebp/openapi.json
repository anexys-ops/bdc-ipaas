{
  "connector_meta": {
    "id": "ebp",
    "name": "EBP",
    "version": "1.0",
    "icon": "https://logo.clearbit.com/ebp.com",
    "category": "ERP / Comptabilité",
    "auth_type": "api_key",
    "modes": ["saas_api", "desktop_csv"],
    "docs_url": "https://developer.ebp.com/",
    "config_instructions": "EBP (SaaS ou Desktop) : 1) Accéder à l’API depuis l’espace EBP (SaaS) ou la configuration du logiciel. 2) Créer ou récupérer une clé API (X-API-Key) dans les paramètres d’intégration / développeur. 3) URL de base : endpoint fourni dans la documentation EBP (ex: https://api.ebp.com/v1 pour SaaS). Conserver la clé en secret. Tester avec une requête GET sur l’URL de base en envoyant l’en-tête X-API-Key."
  },
  "auth_config": {
    "api_key_header": "X-API-Key",
    "base_url_param": "base_url"
  },
  "config_fields": [
    {
      "key": "base_url",
      "label": "URL de base de l’API",
      "type": "text",
      "required": true,
      "placeholder": "https://api.ebp.com/v1",
      "description": "Endpoint de l’API EBP fourni dans la doc (SaaS ou votre instance). Sans slash final."
    },
    {
      "key": "api_key",
      "label": "Clé API (X-API-Key)",
      "type": "password",
      "required": true,
      "placeholder": "Votre clé API EBP",
      "description": "Clé API créée dans EBP (paramètres d’intégration). Envoyée dans l’en-tête X-API-Key."
    }
  ],
  "operations": [
    {
      "id": "list_customers",
      "label": "Récupérer les clients",
      "type": "source",
      "method": "GET",
      "path": "/customers",
      "pagination": "offset",
      "output_schema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "code": { "type": "string" },
          "name": { "type": "string" },
          "address1": { "type": "string" },
          "address2": { "type": "string" },
          "zipCode": { "type": "string" },
          "city": { "type": "string" },
          "country": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "vatNumber": { "type": "string" }
        }
      }
    },
    {
      "id": "list_products",
      "label": "Récupérer les articles",
      "type": "source",
      "method": "GET",
      "path": "/items",
      "pagination": "offset",
      "output_schema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "reference": { "type": "string" },
          "label": { "type": "string" },
          "price": { "type": "number" },
          "vatRate": { "type": "number" },
          "stock": { "type": "number" },
          "ean": { "type": "string" }
        }
      }
    },
    {
      "id": "import_csv_epiece",
      "label": "Importer fichier EPIECE (Desktop)",
      "type": "destination",
      "method": "FILE",
      "file_format": "csv",
      "file_encoding": "windows-1252",
      "file_separator": ";",
      "file_pattern": "EPIECE_{date}.csv",
      "input_schema": {
        "type": "object",
        "required": ["reference", "label", "price"],
        "properties": {
          "reference": { "type": "string", "maxLength": 20 },
          "label": { "type": "string", "maxLength": 60 },
          "price": { "type": "number" },
          "vatRate": { "type": "number" },
          "stock": { "type": "number" },
          "ean": { "type": "string", "maxLength": 13 }
        }
      }
    }
  ]
}
