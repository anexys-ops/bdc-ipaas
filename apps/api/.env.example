NODE_ENV=development
PORT=3000

# Master DB
DATABASE_URL=postgresql://anexys:password@localhost:5432/anexys_master

# Redis
REDIS_URL=redis://localhost:6379

# Redis « gate » (Benthos gate.edicloud.app) — provisioning routes WEBHOOK (BDC-93). Défaut : FLOW_ROUTER_REDIS_URL ou REDIS_URL.
GATE_REDIS_URL=

# URLs publiques affichées / stockées côté gate
GATE_WEBHOOK_PUBLIC_URL=https://gate.edicloud.app/webhook
GATE_INGEST_PUBLIC_URL=https://ultimate.edicloud.app/api/v1/gateway/ingest

# JWT
JWT_ACCESS_SECRET=change-me-to-a-secure-random-string-32-chars
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Vault (32 bytes en hexadécimal = 64 caractères)
VAULT_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=user
SMTP_PASS=pass
SMTP_FROM=noreply@anexys.local

# Connecteurs
CONNECTORS_PATH=../../connectors

# Frontend
FRONTEND_URL=http://localhost:5173

# Keycloak (SSO) — optionnel ; si absent, POST /auth/keycloak renvoie 400
# Issuer = URL du realm (BDC-99 prod : https://auth.bigdataconsulting.fr/realms/anexys)
KEYCLOAK_ISSUER=
# Client public OIDC (même id que VITE_KEYCLOAK_CLIENT_ID, ex. ipaas-app)
KEYCLOAK_CLIENT_ID=
