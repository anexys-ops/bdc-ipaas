# URL de l'API (par défaut : http://localhost:3000/api/v1)
# À définir si le frontend n'est pas sur la même machine que l'API.
# VITE_API_URL=http://localhost:3000/api/v1

# Keycloak (optionnel) — les trois variables activent le bouton « Se connecter en SSO »
# Prod (BDC-99) : https://auth.edicloud.app + realm anexys + client ipaas-app
# VITE_KEYCLOAK_URL=https://auth.edicloud.app
# VITE_KEYCLOAK_REALM=anexys
# VITE_KEYCLOAK_CLIENT_ID=ipaas-app
