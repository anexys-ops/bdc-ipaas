# Copier en .env.production à la racine du repo (ou sur le serveur)
# Ne jamais committer .env.production (mots de passe réels).

POSTGRES_USER=anexys
POSTGRES_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_FORT
POSTGRES_DB=anexys_master

# URL du front en production (pour CORS et cookies)
FRONTEND_URL=https://ultimate.edicloud.app

# Pour le build du frontend (URL d’appels API côté navigateur)
VITE_API_URL=/api/v1

# Optionnel : supervision pipeline (Benthos + clé liste Redis des heartbeats)
# BENTHOS_HTTP_URL=http://benthos:4195
# BENTHOS_REDIS_HEARTBEAT_KEY=benthos_heartbeat

# Optionnel : port HTTP exposé sur l’hôte
HTTP_PORT=80

# --- Keycloak BDC-99 (auth.edicloud.app, realm anexys) ---
# Mot de passe admin console Keycloak (obligatoire si service keycloak dans docker-compose.prod)
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_KEYCLOAK_ADMIN

# Backend : échange du jeton Keycloak (JWKS) — même issuer que le realm
KEYCLOAK_ISSUER=https://auth.edicloud.app/realms/anexys
# Doit correspondre au client public du realm (fichier docker/keycloak/realms/anexys-realm.json)
KEYCLOAK_CLIENT_ID=ipaas-app

# Build frontend (Vite) : les 3 variables activent le bouton « Se connecter en SSO »
VITE_KEYCLOAK_URL=https://auth.edicloud.app
VITE_KEYCLOAK_REALM=anexys
VITE_KEYCLOAK_CLIENT_ID=ipaas-app

# Optionnel : nom d’hôte public (pour FRONTEND_URL si non défini)
# PUBLIC_HOST=86.104.252.67

# SMTP Gmail pour envoi des demandes de démo (compte machine + mot de passe d'application)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=machine@anexys.fr
SMTP_PASS=VOTRE_MOT_DE_PASSE_APPLICATION_GMAIL
SMTP_FROM=Ultimate Edicloud <machine@anexys.fr>
# Destinataire des demandes de démo (formulaire "Réserver une démo")
DEMO_MAIL_TO=commercial@anexys.fr
