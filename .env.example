# ===========================================
# ANEXYS iPaaS - Configuration Environnement
# ===========================================

# ---- Base de données ----
DATABASE_URL=postgresql://anexys:your_password@localhost:5432/anexys_master
DB_PASSWORD=your_secure_password

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT ----
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Chiffrement (32 bytes hex) ----
VAULT_KEY=your-32-byte-hex-key-for-aes-256-encryption

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_PRO=price_pro_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_id

# ---- Email SMTP ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@anexys.com

# ---- Monitoring ----
GRAFANA_PASSWORD=admin_grafana_password

# ---- Connecteurs ----
CONNECTORS_PATH=/app/connectors

# ---- Application ----
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ---- Frontend ----
VITE_API_URL=http://localhost:3000/api/v1

# ---- Keycloak SSO (BDC-99, docker compose) ----
# Mot de passe console admin Keycloak (obligatoire si le service keycloak est actif)
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin
KEYCLOAK_ISSUER=https://auth.edicloud.app/realms/anexys
KEYCLOAK_CLIENT_ID=ipaas-app
VITE_KEYCLOAK_URL=https://auth.edicloud.app
VITE_KEYCLOAK_REALM=anexys
VITE_KEYCLOAK_CLIENT_ID=ipaas-app
FRONTEND_URL=https://ultimate.edicloud.app
